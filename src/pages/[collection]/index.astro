---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import DimensionDivider from '../../components/DimensionDivider.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { COLLECTION_ORDER, COLLECTION_META, type CollectionKey } from '../../data/collections';

export async function getStaticPaths() {
  return COLLECTION_ORDER.map((collection) => ({ params: { collection } }));
}

const collection = Astro.params.collection as CollectionKey;
const meta = COLLECTION_META[collection];

const entries = (await getCollection(collection, ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title={`${meta.label} — Portfolio`} description={meta.blurb}>
  <section class="mx-auto max-w-6xl px-5 pb-4 pt-14">
    <p class="font-mono text-[11px] uppercase tracking-[0.25em] text-brass">Sheet {meta.sheet}</p>
    <h1 class="mt-3 font-display text-3xl font-semibold text-line md:text-4xl">{meta.label}</h1>
    <p class="mt-3 max-w-xl text-line-dim">{meta.blurb}</p>
  </section>

  <DimensionDivider label={`${entries.length} ${entries.length === 1 ? 'entry' : 'entries'}`} />

  <section class="mx-auto max-w-3xl px-5 py-6">
    {entries.length === 0 ? (
      <p class="py-12 text-center font-mono text-sm uppercase tracking-wider text-line-dim">
        Nothing here yet — coming soon.
      </p>
    ) : (
      entries.map((entry) => (
        <ProjectCard
          href={`/${collection}/${entry.id}/`}
          title={entry.data.title}
          summary={entry.data.summary}
          date={entry.data.date}
          tags={entry.data.tags}
        />
      ))
    )}
  </section>
</Layout>
