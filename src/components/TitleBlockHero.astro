---
interface Props {
  name: string;
  role: string;
  intro: string;
  sheetCount: number;
}
const { name, role, intro, sheetCount } = Astro.props;

const cells = [
  { label: 'Drawn By', value: name },
  { label: 'Scale', value: 'NTS' },
  { label: 'Sheet', value: `1 of ${sheetCount}` },
  { label: 'Rev.', value: new Date().toISOString().slice(0, 7) },
];
---

<section class="mx-auto max-w-6xl px-5 pb-10 pt-16 md:pt-24">
  <p class="font-mono text-[11px] uppercase tracking-[0.25em] text-brass">Project Portfolio</p>

  <h1 class="mt-4 max-w-3xl font-display text-4xl font-semibold leading-[1.05] text-line md:text-6xl">
    {name}
  </h1>
  <p class="mt-3 font-mono text-sm uppercase tracking-wider text-line-dim md:text-base">
    {role}
  </p>

  <p class="mt-6 max-w-xl text-balance font-body text-base leading-relaxed text-line-dim md:text-lg">
    {intro}
  </p>

  <!-- Title block: gerçek mühendislik çiziminin köşe damgasından ilham alıyor -->
  <div class="mt-10 grid w-full max-w-xl grid-cols-2 border border-blueprint-lighter/50 sm:grid-cols-4">
    {cells.map((cell, i) => (
      <div class={`px-4 py-3 ${i !== 0 ? 'border-l border-blueprint-lighter/50' : ''}`}>
        <p class="font-mono text-[10px] uppercase tracking-widest text-line-dim">{cell.label}</p>
        <p class="mt-1 font-mono text-sm text-line">{cell.value}</p>
      </div>
    ))}
  </div>
</section>
